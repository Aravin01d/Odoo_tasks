<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
     <record id="employee_loan_line_action" model="ir.actions.act_window">
        <field name="name">Employee Loan Line</field>
        <field name="res_model">employee.loan.line</field>
        <field name="view_mode">list,form</field>
    </record>

        <record id="employee_loan_line_list_view" model="ir.ui.view">
        <field name="name">employee.loan.line.list</field>
        <field name="model">employee.loan.line</field>
        <field name="arch" type="xml">
            <list>
                    <field name="loan_id"/>
                    <field name="date"/>
                    <field name="amount"/>
                    <field name="paid"/>
                </list>
        </field>
    </record>

</odoo>