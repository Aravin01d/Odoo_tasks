<?xml version="1.0" encoding="UTF-8"?>
<odoo>
<data noupdate="1">

        <record model="res.groups.privilege" id="res_groups_privilege_library">
            <field name="name">Library</field>
            <field name="sequence">20</field>
            <field name="category_id" ref="base.module_category_library"/>
        </record>

        <record model="res.groups" id="library_assistant_access">
            <field name="name">Library Assistant</field>
            <field name="sequence">10</field>
            <field name="privilege_id" ref="res_groups_privilege_library"/>
        </record>

        <record model="res.groups" id="librarian_access">
           <field name="name">Librarian</field>
           <field name="sequence">20</field>
           <field name="implied_ids" eval="[(4,ref('library_assistant_access'))]"/>
           <field name="privilege_id" ref="res_groups_privilege_library"/>
           <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

    <record id="library_assistant_rule" model="ir.rule">
        <field name="name">assistant can only see their own checkouts</field>
        <field name="model_id" ref="model_checkouts_model"/>
        <field name="domain_force">[('create_uid','=',user.id)]</field>
        <field name="groups" eval="[4,(ref('library_assistant_access'))]"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_unlink" eval="0"/>
        <field name="perm_read" eval="1"/>
    </record>

    <record id="assistant_books_rule" model="ir.rule">
        <field name="name">assistant can access books for checkout</field>
        <field name="model_id" ref="model_books_model"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[4,(ref('library_assistant_access'))]"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_unlink" eval="0"/>
        <field name="perm_read" eval="1"/>
    </record>

</data>
</odoo>


