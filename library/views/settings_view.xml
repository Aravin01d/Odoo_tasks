<odoo>
<data>
    <record id="res_config_settings_action" model="ir.actions.act_window">
       <field name="name">Settings</field>
       <field name="res_model">res.config.settings</field>
       <field name="view_mode">form</field>
       <field name="context">{'module' : 'library'}</field>
   </record>

   <record id="res_config_settings_view_form" model="ir.ui.view">
       <field name="name">
           res.config.settings.view.form
       </field>
       <field name="model">res.config.settings</field>
       <field name="priority" eval="15"/>
       <field name="inherit_id" ref="base.res_config_settings_view_form"/>
       <field name="arch" type="xml">
           <xpath expr="//form" position="inside">
               <app data-string="library"
                    string="Library" name="library">
                   <block title="Library Settings"
                          name="library">

                       <setting string="Borrow days"
                                help="Set the borrow days"
                                id="borrow_days_id">
                           <field name="borrow_days"/>
                           <div class="content-group"
                                invisible="not borrow_days"
                                id="group_borrow_days_setting">
                               <div class="text-warning mt16">
                                   <strong>Save</strong>
                                   this page and come back here to set up the
                                   feature.
                               </div>
                           </div>
                       </setting>

                       <setting string="Reminder Days"
                                help="Set the reminder days before a book is due"
                                id="reminder_days_id">
                           <field name="reminder_days"/>
                           <div class="content-group"
                                invisible="not reminder_days"
                                id="group_reminder_days_setting">
                               <div class="text-warning mt16">
                                   <strong>Save</strong>
                                   this page and come back here to set up the
                                   feature.
                               </div>
                           </div>
                       </setting>

                       <setting string="Penalty Amount"
                                help="Set the Penalty Amount"
                                id="penalty_amount_id">
                           <field name="penalty_amount"/>
                           <div class="content-group"
                                invisible="not penalty_amount"
                                id="group_penalty_amount_setting">
                               <div class="text-warning mt16">
                                   <strong>Save</strong>
                                   this page and come back here to set up the
                                   feature.
                               </div>
                           </div>
                       </setting>

                       <setting string="Maximum Books"
                                help="Set the maximum books allowed for a member"
                                id="max_books_id">
                           <field name="max_books"/>
                           <div class="content-group"
                                invisible="not max_books"
                                id="group_max_books_setting">
                               <div class="text-warning mt16">
                                   <strong>Save</strong>
                                   this page and come back here to set up the
                                   feature.
                               </div>
                           </div>
                       </setting>

                       <setting string="Maximum Late Returns"
                                help="Set the maximum late returns allowed for a member"
                                id="max_late_returns_id">
                           <field name="max_late_returns"/>
                           <div class="content-group"
                                invisible="not max_late_returns"
                                id="group_max_late_returns_setting">
                               <div class="text-warning mt16">
                                   <strong>Save</strong>
                                   this page and come back here to set up the
                                   feature.
                               </div>
                           </div>
                       </setting>

                   </block>

                   <block title="Product Settings"
                          name="Product">

                        <setting string="Product Threshold"
                                help="Set the threshold for products"
                                id="product_threhold_id">
                           <field name="product_threshold"/>
                           <div class="content-group"
                                invisible="not product_threshold"
                                id="group_product_threshold_setting">
                               <div class="text-warning mt16">
                                   <strong>Save</strong>
                                   this page and come back here to set up the
                                   feature.
                               </div>
                           </div>
                       </setting>

                   </block>
               </app>
             </xpath>
       </field>
   </record>

    </data>

    <menuitem id="library_menu_root"
             name="library setting"
              groups="librarian_access,library_assistant_access"
             sequence="3"/>
    <menuitem id="library_menu_action"
             name="Configuration"
              groups="librarian_access"
             parent="library.library_menu_root"
             />
    <menuitem id="library_settings_menu_action"
             name="Settings"
             parent="library.library_menu_action"
             action="res_config_settings_action"/>
</odoo>
