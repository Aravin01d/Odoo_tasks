<odoo>

    <record id="checkouts_model_action" model="ir.actions.act_window">
    <field name="name">Checkouts</field>
    <field name="res_model">checkouts.model</field>
    <field name="view_mode">list,form</field>
    </record>

    <record id="checkouts_list_view" model="ir.ui.view">
    <field name="name">checkouts.list</field>
    <field name="model">checkouts.model</field>
    <field name="arch" type="xml">
        <list>
            <field name="book_ids"/>
            <field name="member_id"/>
            <field name="checkout_date"/>
            <field name="return_date"/>
            <field name="status"/>
            <field name="is_late"/>
        </list>
    </field>
    </record>

