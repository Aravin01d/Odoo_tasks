<odoo>

        <record id="authors_model_action" model="ir.actions.act_window">
        <field name="name">Authors</field>
        <field name="res_model">authors.model</field>
        <field name="view_mode">list,form</field>
        </record>

        <record id="authors_list_view" model="ir.ui.view">
        <field name="name">authors.list</field>
        <field name="model">authors.model</field>
        <field name="arch" type="xml">
                <list>
                        <field name="author_name"/>
                        <field name="description"/>
                </list>
        </field>
        </record>

        <record id="authors_form_view" model="ir.ui.view">
                <field name="name">authors.form</field>
                <field name="model">authors.model</field>
                <field name="arch" type="xml">
                <form>
                        <group>
                                <field name="author_name"/>
                                <field name="description"/>
                                <field name="book_ids"/>
                        </group>
                </form>
                </field>
        </record>

</odoo>


