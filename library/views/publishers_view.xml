<odoo>

    <record id="publishers_model_action" model="ir.actions.act_window">
    <field name="name">Publishers</field>
    <field name="res_model">publishers.model</field>
    <field name="view_mode">list,form</field>
    </record>

    <record id="publishers_list_view" model="ir.ui.view">
    <field name="name">publishers.list</field>
    <field name="model">publishers.model</field>
    <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="address"/>
            </list>
    </field>
    </record>

    <record id="publishers_form_view" model="ir.ui.view">
        <field name="name">publishers.form</field>
        <field name="model">publishers.model</field>
        <field name="arch" type="xml">
                <form>
                    <group>
                        <field name="name"/>
                        <field name="address"/>
                        <field name="publisher_book_ids"/>
                    </group>
                </form>
        </field>
    </record>

</odoo>

