<odoo>

    <record id="genres_model_action" model="ir.actions.act_window">
    <field name="name">Genres</field>
    <field name="res_model">genres.model</field>
    <field name="view_mode">list,form</field>
    </record>

    <record id="genres_list_view" model="ir.ui.view">
        <field name="name">genres.list</field>
        <field name="model">genres.model</field>
        <field name="arch" type="xml">
                <list>
                    <field name="genre_name"/>
                </list>
        </field>
    </record>

    <record id="genres_form_view" model="ir.ui.view">
        <field name="name">genres.form</field>
        <field name="model">genres.model</field>
        <field name="arch" type="xml">
                <form>
                    <group>
                        <group>
                        <field name="genre_name"/>
                        </group>
                    </group>
                </form>
        </field>
    </record>

</odoo>

