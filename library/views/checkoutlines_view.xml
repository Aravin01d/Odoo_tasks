<odoo>
    <record id="checkoutlines_model_action" model="ir.actions.act_window">
        <field name="name">Checkout Lines</field>
        <field name="res_model">checkoutlines.model</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="checkoutlines_model_list_view" model="ir.ui.view">
        <field name="name">checkoutlines.list</field>
        <field name="model">checkoutlines.model</field>
        <field name="arch" type="xml">
                <list>
                    <field name="book_line_id"/>
                    <field name="checkout_date"/>
                    <field name="return_date"/>

                </list>
        </field>
    </record>

    <record id="checkoutlines_model_form_view" model="ir.ui.view">
        <field name="name">checkoutlines.form</field>
        <field name="model">checkoutlines.model</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="book_line_id"/>
                    <field name="checkout_line_id"/>
                    <field name="price"/>
                    <field name="status"/>
                </group>
          </form>
        </field>
    </record>
</odoo>
