<odoo>

<record id="suggest_book_action" model="ir.actions.act_window">
    <field name="name">Suggest Book</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">suggestbook.model</field>
    <field name="view_mode">list,form</field>
</record>

    <record id="suggestboook_view_form" model="ir.ui.view">
    <field name="name">suggestbook.view.form</field>
    <field name="model">suggestbook.model</field>
    <field name="arch" type="xml">
    <form string="Suggest Book">
    <group>
        <list>
            <field name="name_ids"/>
            </list>
        </group>
        <footer>
         <button type="object" name="suggest_book" class="btn btn-primary"
                        string="Add"/>
        <button string="Cancel" special="cancel"/>
        </footer>
   </form>
    </field>
    </record>

</odoo>

