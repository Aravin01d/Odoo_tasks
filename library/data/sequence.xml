<?xml version="1.0" encoding="utf-8" ?>
<odoo>

   <data noupdate="1">
       <record id="ir_sequence_book_id" model="ir.sequence">
           <field name="name">Book ID</field>
           <field name="code">books.model</field>
           <field name="prefix">BID</field>
           <field name="padding">5</field>
           <field name="number_next">1</field>
           <field name="number_increment">1</field>
           <field name="company_id" eval="False"/>
       </record>
   </data>

    <data noupdate="1">
       <record id="ir_sequence_checkouts_id" model="ir.sequence">
           <field name="name">Checkout ID</field>
           <field name="code">checkouts.model</field>
           <field name="prefix">COID</field>
           <field name="padding">5</field>
           <field name="number_next">1</field>
           <field name="number_increment">1</field>
           <field name="company_id" eval="False"/>
       </record>
   </data>
</odoo>

