<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="res_partner_form_inherit" model="ir.ui.view">
            <field name="name">res.partner.form.inherit</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='category_id']" position="after">
                    <field name="product_variant_ids" widget="many2many_tags"/>
                </xpath>

                <xpath expr="//field[@name='product_variant_ids']" position="after">
                    <button class="btn-primary" type="object" name="action_recalculate">Recalculate</button>
                </xpath>
                <xpath expr="//button[@name='action_recalculate']" position="after">
                    <button class="btn-primary" type="object" name="action_add_so">Add Sale Order</button>
                </xpath>
            </field>
        </record>
    </data>
</odoo>